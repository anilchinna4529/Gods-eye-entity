# Copy this file to `.env` at the repo root.

# Postgres
POSTGRES_USER=godseye
POSTGRES_PASSWORD=godseye
POSTGRES_DB=godseye
DATABASE_URL=postgresql://godseye:godseye@db:5432/godseye

# Redis
REDIS_URL=redis://redis:6379/0
EVENTS_CHANNEL=godseye.events

# API auth
JWT_SECRET=dev-change-me
JWT_EXP_MINUTES=720
SESSION_COOKIE_SECURE=0
CORS_ORIGINS=http://localhost:3000

# Bootstrap admin user (first run only, if the DB is empty)
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me

# Web UI runtime
NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXT_PUBLIC_WS_BASE=ws://localhost:8000

